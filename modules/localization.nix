# ============================================
# 本地化配置模块
# 配置时区、语言和控制台字体
# ============================================

{ config, pkgs, ... }:

{
  # ============================================
  # 时区设置
  # ============================================
  time.timeZone = "Asia/Shanghai";  # 设置时区为亚洲/上海

  # ============================================
  # 语言环境设置
  # ============================================
  i18n.defaultLocale = "zh_CN.UTF-8";  # 默认语言环境：中文（UTF-8）
  i18n.extraLocaleSettings = {
    LC_TIME = "zh_CN.UTF-8";        # 时间格式（如 2024年1月1日）
    LC_MONETARY = "zh_CN.UTF-8";    # 货币格式（如 ¥1,000）
    LC_PAPER = "zh_CN.UTF-8";       # 纸张格式（如 A4）
    LC_MEASUREMENT = "zh_CN.UTF-8"; # 度量单位（如 米、千克）
  };

  # ============================================
  # 控制台字体配置
  # ============================================
  console.font = "ter-u28n";                  # 使用 terminus 字体（支持中文）
  console.packages = [ pkgs.terminus_font ];  # 安装 terminus 字体包
}
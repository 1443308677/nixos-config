# ============================================
# 软件包配置模块
# 配置系统级软件包和程序
# ============================================

{ config, pkgs, ... }:

{
  # ============================================
  # 系统级软件包
  # 所有用户均可使用的命令行工具
  # ============================================
  environment.systemPackages = with pkgs; [
    vim         # 经典文本编辑器
    wget        # 命令行下载工具
    git         # 版本控制系统
    curl        # HTTP 客户端工具
    htop        # 交互式系统监控
    fastfetch   # 系统信息展示工具
  ];

  # ============================================
  # 允许使用的 Shell
  # 用户可选择的登录 Shell
  # ============================================
  environment.shells = [ pkgs.bash pkgs.fish ];

  # ============================================
  # 程序模块配置
  # 通过 modules 方式安装的应用
  # ============================================
  programs.firefox.enable = true;  # 安装 Firefox 浏览器（会在应用菜单显示）
}
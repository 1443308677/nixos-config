# ============================================
# Home Manager 用户配置
# 用户 kinos 的个人配置文件
# ============================================

{ config, pkgs, lib, ... }:

{
  # ============================================
  # 导入其他用户配置模块（可选）
  # ============================================
  imports = [ ];

  # ============================================
  # 用户基本信息
  # ============================================
  home.username = "kinos";           # 用户名
  home.homeDirectory = "/home/kinos";  # 家目录路径
  home.stateVersion = "25.11";       # Home Manager 状态版本

  # ============================================
  # 用户级软件包
  # 仅当前用户可使用的应用程序
  # ============================================
  home.packages = with pkgs; [
    helix  # 现代化文本编辑器
  ];

  # ============================================
  # 用户级程序配置
  # ============================================
  programs.fish.enable = true;  # 启用 Fish shell 配置管理
}
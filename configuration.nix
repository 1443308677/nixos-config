# ============================================
# NixOS 主配置文件
# 作为系统配置的入口，导入所有功能模块
# ============================================

{ config, pkgs, ... }:

{
  # ============================================
  # 导入配置模块
  # 按功能分类组织的子配置文件
  # ============================================
  imports = [
    ./hardware-configuration.nix  # 硬件配置（每台机器自动生成，不提交到 Git）
    ./modules/boot.nix            # 启动配置（bootloader、内核）
    ./modules/networking.nix      # 网络配置（hostname、网络管理）
    ./modules/localization.nix    # 本地化配置（时区、语言）
    ./modules/desktop.nix         # 桌面环境配置（GNOME、音效、输入法）
    ./modules/users.nix           # 用户配置（账户、权限）
    ./modules/packages.nix        # 系统包配置（预装软件）
  ];

  # ============================================
  # Nix 配置选项
  # ============================================
  nix.settings.experimental-features = [ "nix-command" "flakes" ];  # 启用 Nix Flakes

  # ============================================
  # 系统状态版本
  # 保持与安装时一致，用于兼容性保证
  # ============================================
  system.stateVersion = "25.11";
}
